---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import categorie from '../../data/categorie.json';

const allTesi = await getCollection('tesi');
const publishedTesi = allTesi.filter(t => t.data.status === 'published' || t.data.status === 'draft');

// Raggruppa per macro-area
const tesiByArea = new Map<string, typeof publishedTesi>();
const tesiSenzaArea: typeof publishedTesi = [];

for (const tesi of publishedTesi) {
  if (tesi.data.macroArea) {
    const list = tesiByArea.get(tesi.data.macroArea) || [];
    list.push(tesi);
    tesiByArea.set(tesi.data.macroArea, list);
  } else {
    tesiSenzaArea.push(tesi);
  }
}

function formatDate(iso: string) {
  try {
    return new Date(iso).toLocaleDateString('it-IT', { day: 'numeric', month: 'short', year: 'numeric' });
  } catch { return iso; }
}
---

<BaseLayout title="Tesi Programmatiche ORA!" description="Le Tesi Programmatiche di ORA! come bussola di orientamento politico per il lavoro dei gruppi tematici.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[{ label: 'Tesi Programmatiche ORA!' }]} />

    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-10">
        <h1 class="text-3xl md:text-4xl font-extrabold text-primary-900 mb-4">
          Tesi Programmatiche di ORA!
        </h1>
        <p class="text-lg text-gray-600 leading-relaxed">
          Le posizioni del partito sulle principali questioni politiche regionali,
          organizzate come <strong>bussola di orientamento politico</strong> per il lavoro dei gruppi tematici.
        </p>
      </div>

      {publishedTesi.length === 0 ? (
        <!-- Stato vuoto: nessuna tesi caricata -->
        <div class="text-center py-12">
          <div class="inline-flex items-center gap-2 bg-amber-50 text-amber-800 text-sm font-medium px-4 py-2 rounded-full mb-6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
            Tesi in fase di caricamento
          </div>
          <p class="text-gray-500 mb-8">Le Tesi Programmatiche saranno pubblicate a breve.</p>

          <div class="bg-primary-50 border border-primary-200 rounded-xl p-6 text-left max-w-2xl mx-auto">
            <h2 class="font-bold text-primary-900 mb-3">Struttura prevista</h2>
            <div class="space-y-3">
              {categorie.map(cat => (
                <div class="flex items-center gap-3 bg-white/60 rounded-lg p-3">
                  <span class="w-3 h-3 rounded-full shrink-0" style={`background:${cat.colore}`}></span>
                  <div>
                    <div class="font-semibold text-sm text-gray-900">{cat.nome}</div>
                    <div class="text-xs text-gray-500">{cat.descrizione}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ) : (
        <!-- Tesi pubblicate -->
        <div class="space-y-8">
          <!-- Contatore -->
          <div class="flex items-center gap-4 text-sm text-gray-500">
            <span class="bg-primary-100 text-primary-800 font-semibold px-3 py-1 rounded-full">
              {publishedTesi.length} tesi
            </span>
          </div>

          <!-- Tesi per macro-area -->
          {categorie.map(cat => {
            const tesiArea = tesiByArea.get(cat.id) || [];
            if (tesiArea.length === 0) return null;
            return (
              <div class="mb-8">
                <div class="flex items-center gap-3 mb-4">
                  <span class="w-4 h-4 rounded-full shrink-0" style={`background:${cat.colore}`}></span>
                  <h2 class="text-xl font-bold text-gray-900">{cat.nome}</h2>
                  <span class="text-xs text-gray-400">({tesiArea.length})</span>
                </div>
                <div class="grid gap-3">
                  {tesiArea.map(tesi => (
                    <a href={`/tesi/${tesi.data.slug}/`}
                       class="block bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md hover:border-gray-300 transition-all group">
                      <div class="flex items-start justify-between gap-4">
                        <div class="flex-1">
                          <div class="flex items-center gap-2 mb-1">
                            {tesi.data.status === 'draft' && (
                              <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded bg-yellow-100 text-yellow-800">Bozza</span>
                            )}
                            <time class="text-[10px] text-gray-400">{formatDate(tesi.data.lastUpdated)}</time>
                          </div>
                          <h3 class="text-sm font-semibold text-gray-900 group-hover:text-primary-600 transition-colors">
                            {tesi.data.title}
                          </h3>
                          {tesi.data.description && (
                            <p class="text-xs text-gray-500 mt-1 line-clamp-2">{tesi.data.description}</p>
                          )}
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                          {tesi.data.pdfFile && (
                            <span class="text-[10px] text-gray-400 bg-gray-50 px-2 py-0.5 rounded">PDF</span>
                          )}
                          <svg class="w-4 h-4 text-gray-300 group-hover:text-primary-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                          </svg>
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}

          <!-- Tesi senza macro-area -->
          {tesiSenzaArea.length > 0 && (
            <div class="mb-8">
              <div class="flex items-center gap-3 mb-4">
                <span class="w-4 h-4 rounded-full shrink-0 bg-gray-400"></span>
                <h2 class="text-xl font-bold text-gray-900">Altre Tesi</h2>
                <span class="text-xs text-gray-400">({tesiSenzaArea.length})</span>
              </div>
              <div class="grid gap-3">
                {tesiSenzaArea.map(tesi => (
                  <a href={`/tesi/${tesi.data.slug}/`}
                     class="block bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md hover:border-gray-300 transition-all group">
                    <div class="flex items-start justify-between gap-4">
                      <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                          {tesi.data.status === 'draft' && (
                            <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded bg-yellow-100 text-yellow-800">Bozza</span>
                          )}
                          <time class="text-[10px] text-gray-400">{formatDate(tesi.data.lastUpdated)}</time>
                        </div>
                        <h3 class="text-sm font-semibold text-gray-900 group-hover:text-primary-600 transition-colors">
                          {tesi.data.title}
                        </h3>
                        {tesi.data.description && (
                          <p class="text-xs text-gray-500 mt-1 line-clamp-2">{tesi.data.description}</p>
                        )}
                      </div>
                      <div class="flex items-center gap-2 shrink-0">
                        {tesi.data.pdfFile && (
                          <span class="text-[10px] text-gray-400 bg-gray-50 px-2 py-0.5 rounded">PDF</span>
                        )}
                        <svg class="w-4 h-4 text-gray-300 group-hover:text-primary-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      <!-- Nota importante -->
      <div class="mt-10 bg-gray-50 border border-gray-200 rounded-xl p-6">
        <h3 class="font-bold text-gray-900 mb-2">Nota importante</h3>
        <p class="text-sm text-gray-600 leading-relaxed">
          Questa e l'<strong>unica sezione del sito con contenuti di natura politica</strong>.
          Tutte le altre sezioni (tematiche, dati, fonti) contengono informazioni
          oggettive e neutrali provenienti da fonti istituzionali.
          Le Tesi Programmatiche rappresentano invece le posizioni e le proposte
          politiche di ORA! sulle tematiche monitorate.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
