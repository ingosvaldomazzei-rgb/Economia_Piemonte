---
import BaseLayout from '../layouts/BaseLayout.astro';
import KpiGrid from '../components/KpiGrid.astro';
import CategoryCard from '../components/CategoryCard.astro';
import TemaCard from '../components/TemaCard.astro';
import NewsFeed from '../components/NewsFeed.astro';
import LastUpdateBadge from '../components/LastUpdateBadge.astro';
import categorie from '../data/categorie.json';
import notiziPerTema from '../data/auto/notizie-per-tema.json';
import { getCollection } from 'astro:content';

const allTemi = await getCollection('temi');
const pilotTemi = allTemi.filter(t => t.data.isPilotDeepDive).sort((a, b) => a.data.priorita - b.data.priorita);

// Count news per category
function countNewsForCategory(catId: string): number {
  const cat = categorie.find(c => c.id === catId);
  if (!cat) return 0;
  return cat.temi.reduce((sum: number, temaSlug: string) => {
    return sum + ((notiziPerTema as Record<string, any[]>)[temaSlug]?.length || 0);
  }, 0);
}
---

<BaseLayout>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="max-w-3xl">
        <div class="mb-4">
          <LastUpdateBadge />
        </div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold mb-4 leading-tight">
          Osservatorio Politico<br/>Piemonte
        </h1>
        <p class="text-lg text-white/80 mb-6 leading-relaxed">
          Monitoraggio automatico delle discussioni politiche regionali e comunali.
          Dati, fonti istituzionali e analisi tematiche per i gruppi di lavoro di ORA!
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/temi/" class="inline-flex items-center gap-2 bg-white text-primary-900 font-semibold px-5 py-2.5 rounded-lg hover:bg-gray-100 transition-colors text-sm">
            Esplora le tematiche
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="/fonti/" class="inline-flex items-center gap-2 bg-white/10 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-white/20 transition-colors text-sm border border-white/20">
            Catalogo fonti
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-10">
    <!-- KPI Dashboard -->
    <section>
      <h2 class="text-lg font-bold text-gray-900 mb-4">Indicatori Piemonte</h2>
      <KpiGrid />
    </section>

    <!-- Pilot Deep-Dives -->
    {pilotTemi.length > 0 && (
      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-900">Approfondimenti Pilota</h2>
          <a href="/temi/" class="text-sm text-primary-600 hover:text-primary-800 font-medium">Tutte le tematiche &rarr;</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {pilotTemi.map(tema => (
            <TemaCard
              slug={tema.data.slug}
              title={tema.data.title}
              description={tema.data.description}
              categoria={tema.data.categoria}
              isPilotDeepDive={true}
              kpis={tema.data.kpis}
              newsCount={(notiziPerTema as Record<string, any[]>)[tema.data.slug]?.length}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Main content: News + Categories -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- News Feed (2/3) -->
      <section class="lg:col-span-2">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-900">Ultime Notizie</h2>
          <div class="flex items-center gap-2 text-xs text-gray-400">
            <span class="inline-block w-2 h-2 rounded-full bg-green-500 animate-live-pulse"></span>
            Feed automatico
          </div>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-4">
          <NewsFeed limit={12} />
        </div>
      </section>

      <!-- Categories sidebar (1/3) -->
      <section>
        <h2 class="text-lg font-bold text-gray-900 mb-4">Aree Tematiche</h2>
        <div class="space-y-3">
          {categorie.map(cat => (
            <CategoryCard
              id={cat.id}
              nome={cat.nome}
              colore={cat.colore}
              coloreBg={cat.coloreBg}
              descrizione={cat.descrizione}
              temiCount={cat.temi.length}
              newsCount={countNewsForCategory(cat.id)}
            />
          ))}
        </div>
      </section>
    </div>

    <!-- Council Activity Indicators -->
    <section class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">Attivita Consiliare 2025</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600">306</div>
          <div class="text-xs text-gray-500 mt-1">Interrogazioni</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600">329</div>
          <div class="text-xs text-gray-500 mt-1">Mozioni e OdG</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600">337</div>
          <div class="text-xs text-gray-500 mt-1">Sedute Commissioni</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600">6</div>
          <div class="text-xs text-gray-500 mt-1">Commissioni Permanenti</div>
        </div>
      </div>
      <p class="text-xs text-gray-400 mt-4 text-center">
        Fonte: <a href="https://www.cr.piemonte.it/" target="_blank" rel="noopener" class="underline hover:text-primary-600">Consiglio Regionale del Piemonte</a>
      </p>
    </section>
  </div>
</BaseLayout>
