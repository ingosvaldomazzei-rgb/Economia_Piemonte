---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

let briefing: any = null;
let archivio: any[] = [];

try {
  briefing = (await import('../../data/auto/briefing.json')).default;
} catch {
  briefing = null;
}

try {
  archivio = (await import('../../data/auto/briefing-archivio.json')).default;
} catch {
  archivio = [];
}

// Icone per i temi
const temaIcons: Record<string, string> = {
  heart: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />',
  banknotes: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />',
  briefcase: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zM16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" />',
  truck: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10M13 16H3m10 0h2m4 0h2M15 6h2l3 5v5h-2" />',
  building: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />',
  bolt: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />',
  train: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17l-2 4M16 17l2 4M12 2v2M7 7h10M5 12h14M7 17h10M9 7v10M15 7v10" />',
  leaf: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />',
  globe: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
  palette: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />',
  trophy: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />',
  academic: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />',
  newspaper: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />',
};

const fonteColors: Record<string, string> = {
  regione: 'bg-blue-50 text-blue-700',
  consiglio: 'bg-purple-50 text-purple-700',
  arpa: 'bg-green-50 text-green-700',
  comune_torino: 'bg-red-50 text-red-700',
  torinoclick: 'bg-orange-50 text-orange-700',
  quotidiano_piemontese: 'bg-cyan-50 text-cyan-700',
  ires: 'bg-indigo-50 text-indigo-700',
  unioncamere: 'bg-yellow-50 text-yellow-700',
};

function formatDate(dateStr: string): string {
  try {
    const d = new Date(dateStr);
    return d.toLocaleDateString('it-IT', { day: 'numeric', month: 'short', year: 'numeric' });
  } catch {
    return dateStr;
  }
}
---

<BaseLayout title="Briefing Settimanale" description="Riepilogo settimanale delle notizie più rilevanti dal Piemonte">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
      <Breadcrumb items={[{ label: 'Briefing Settimanale' }]} />
      <h1 class="text-3xl md:text-4xl font-extrabold mb-2 mt-4">Briefing Settimanale</h1>
      {briefing && (
        <p class="text-lg text-white/80">
          {briefing.data_inizio} &mdash; {briefing.data_fine}
        </p>
      )}
      {briefing && (
        <p class="text-sm text-white/50 mt-2">
          Generato il {briefing.generato_il_it}
        </p>
      )}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {!briefing || briefing.temi.length === 0 ? (
      <div class="text-center py-16 text-gray-400">
        <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        <p class="text-lg font-medium text-gray-500">Nessun briefing disponibile</p>
        <p class="text-sm mt-1">Il briefing viene generato automaticamente ad ogni aggiornamento dei dati.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Briefing principale (2/3) -->
        <div class="lg:col-span-2 space-y-6">
          {briefing.temi.map((tema: any) => (
            <section class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-primary-50 flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={temaIcons[tema.icon] || temaIcons.newspaper} />
                </div>
                <div>
                  <h2 class="font-bold text-gray-900">{tema.label}</h2>
                  <span class="text-xs text-gray-400">{tema.notizie.length} {tema.notizie.length === 1 ? 'notizia' : 'notizie'}</span>
                </div>
              </div>
              <div class="divide-y divide-gray-50">
                {tema.notizie.map((n: any) => (
                  <article class="px-5 py-4">
                    <div class="flex items-center gap-2 mb-1.5">
                      <span class={`text-[10px] font-semibold px-1.5 py-0.5 rounded ${fonteColors[n.fonte_id] || 'bg-gray-100 text-gray-600'}`}>
                        {n.fonte}
                      </span>
                      <time class="text-[10px] text-gray-400">{formatDate(n.data)}</time>
                    </div>
                    <a href={n.link} target="_blank" rel="noopener" class="text-sm font-medium text-gray-900 hover:text-primary-600 transition-colors">
                      {n.titolo}
                    </a>
                    {n.descrizione && (
                      <p class="text-xs text-gray-500 mt-1 line-clamp-2">{n.descrizione}</p>
                    )}
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>

        <!-- Sidebar statistiche (1/3) -->
        <div class="space-y-6">
          <!-- Riepilogo -->
          <div class="bg-white rounded-xl border border-gray-200 p-5">
            <h3 class="font-bold text-gray-900 mb-4">Riepilogo Settimana</h3>
            <div class="text-center mb-4">
              <div class="text-4xl font-extrabold text-primary-600">{briefing.statistiche.totale_notizie}</div>
              <div class="text-xs text-gray-500 mt-1">notizie raccolte</div>
            </div>

            {Object.keys(briefing.statistiche.per_fonte).length > 0 && (
              <div class="mb-4">
                <h4 class="text-xs font-semibold text-gray-400 uppercase mb-2">Per fonte</h4>
                <div class="space-y-1.5">
                  {Object.entries(briefing.statistiche.per_fonte).map(([fonte, count]: [string, any]) => (
                    <div class="flex items-center justify-between text-xs">
                      <span class="text-gray-600 truncate">{fonte}</span>
                      <span class="font-semibold text-gray-900 ml-2">{count}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {Object.keys(briefing.statistiche.per_tema).length > 0 && (
              <div>
                <h4 class="text-xs font-semibold text-gray-400 uppercase mb-2">Per tema</h4>
                <div class="space-y-1.5">
                  {Object.entries(briefing.statistiche.per_tema).slice(0, 8).map(([tema, count]: [string, any]) => (
                    <div class="flex items-center justify-between text-xs">
                      <span class="text-gray-600 truncate">{tema}</span>
                      <span class="font-semibold text-gray-900 ml-2">{count}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Archivio -->
          {archivio.length > 1 && (
            <div class="bg-white rounded-xl border border-gray-200 p-5">
              <h3 class="font-bold text-gray-900 mb-3">Archivio Briefing</h3>
              <div class="space-y-2">
                {archivio.slice(1).map((b: any, i: number) => (
                  <div class="flex items-center justify-between text-xs p-2 rounded-lg bg-gray-50">
                    <span class="text-gray-600">
                      {b.data_inizio} &mdash; {b.data_fine}
                    </span>
                    <span class="text-gray-400">{b.statistiche?.totale_notizie || 0} notizie</span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
