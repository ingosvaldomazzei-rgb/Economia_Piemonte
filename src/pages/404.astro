---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pagina non trovata">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <div class="text-6xl font-extrabold text-primary-200 mb-4">404</div>
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Pagina non trovata</h1>
    <p class="text-gray-600 mb-8">La pagina che stai cercando non esiste o e stata spostata.</p>
    <div class="flex justify-center gap-4">
      <a href="/" class="bg-primary-600 text-white font-medium px-5 py-2.5 rounded-lg hover:bg-primary-700 transition-colors text-sm">
        Torna alla Homepage
      </a>
      <a href="/temi/" class="bg-gray-100 text-gray-700 font-medium px-5 py-2.5 rounded-lg hover:bg-gray-200 transition-colors text-sm">
        Esplora le Tematiche
      </a>
    </div>
  </div>
</BaseLayout>
